# FaithfulC Recipe Box — environment configuration
# Copy to .env for local development. In the cluster these are injected from the
# `app-secrets` / infra-secrets Secret; never hardcode connection details.

# PostgreSQL connection string (provided by the postgresql deployment).
DATABASE_URL=

# Secret used to sign/verify JWTs (HS256). Use a long random value in production.
JWT_SECRET=

# Port the single-container app listens on.
PORT=8080

# Demo account seeded on startup (documented login for the demo happy path).
DEMO_USERNAME=demo
DEMO_PASSWORD=demo1234

# --- Optional server tunables (sensible defaults applied when unset) ----------
# JWT_EXP=2h
# PG_POOL_MAX=10
# PG_CONNECT_TIMEOUT_MS=5000
# STATIC_DIR=./public
